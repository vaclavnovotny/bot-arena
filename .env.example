# Cloudflare Turnstile — get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# For local dev / CI you can use the always-passes test pair below.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Required only for playwright/external/odoo-spreadsheet.spec.ts.
# Create a free Odoo trial at https://www.odoo.com/trial, upload
# odoo-erp-mock.xlsx (generated by scripts/gen-erp-xlsx.mjs) into the
# Documents app, then paste the trial credentials here. The spec falls back
# to inline defaults if these are unset — those defaults belong to the
# maintainer's throwaway trial and should not be relied on by forks.
ODOO_EMAIL=
ODOO_PASSWORD=
