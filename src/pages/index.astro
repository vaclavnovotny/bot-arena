---
import '../styles/global.css';

const sections = [
  {
    name: 'Bot detection',
    slug: 'bot-detection',
    description: 'The site detects automation through fingerprinting, behavioural signals, or third-party challenge.',
    levels: [
      { localN: 1, name: 'The honest tell', blurb: 'navigator.webdriver and other passive Chrome flags.' },
      { localN: 2, name: 'CDP attached', blurb: 'Headless-window shape, missing chrome.app / chrome.csi.' },
      { localN: 3, name: 'Mouse trajectory', blurb: 'Mousemove density, click curvature, keystroke cadence.' },
      { localN: 4, name: 'Fingerprint battery', blurb: 'Canvas, audio, font, and WebGL signals.' },
      { localN: 5, name: 'Cloudflare Turnstile', blurb: 'Managed-mode widget with server-side verification.' },
    ],
  },
  {
    name: 'Selector resistance',
    slug: 'selector-resistance',
    description: 'The DOM that selector-based automation depends on is absent, randomised, sealed, or in a different frame.',
    levels: [
      { localN: 1, name: 'Canvas-rendered login', blurb: 'No DOM form — pixels only on a &lt;canvas&gt;.' },
      { localN: 2, name: 'Dynamic selectors', blurb: 'Real form, but every id/name/class rerolls per request.' },
      { localN: 3, name: 'Closed Shadow DOM', blurb: 'Form inside a web component with a sealed shadow root.' },
      { localN: 4, name: 'Iframe-embedded form', blurb: 'Form lives in a child frame; page-scoped locators miss it.' },
      { localN: 5, name: 'Slider verification', blurb: 'Drag a knob into a target zone whose position is only visible in pixels.' },
      { localN: 6, name: 'Image-only labels', blurb: 'Form labels rendered as SVG images. No DOM text.' },
      { localN: 7, name: 'Cross-origin iframe', blurb: 'Form in a cross-origin frame — browser security blocks selectors.' },
      { localN: 8, name: 'Virtual scrolling', blurb: '1,000-row account list with windowed rendering; off-screen items are not in the DOM.' },
    ],
  },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Bot Arena — anti-bot detection demo</title>
    <meta name="description" content="Seven levels in two sections: five anti-bot detections, plus two selector-resistant rendering tricks. A demo target for browser automation." />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-lg font-semibold tracking-tight"><img src="/favicon.svg" alt="" class="h-6 w-6" /><span>Bot Arena</span></a>
        <nav class="flex gap-4 text-sm text-slate-600">
          <a href="/report" class="hover:text-slate-900">Failure report</a>
          <a href="/other-usecases" class="hover:text-slate-900">Other use-cases</a>
          <a href="/about" class="hover:text-slate-900">About</a>
          <a href="https://github.com/vaclavnovotny/bot-arena" class="hover:text-slate-900">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">A live demo</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
        Where automation gets caught — or can't even try.
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Two sections, seven levels. The first five are about <strong>detection</strong> — the site sees you and refuses. The last two are about <strong>capability</strong> — selector-based automation cannot interact with what it cannot find.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/bot-detection/level-1/"
          class="inline-block rounded-lg bg-slate-900 px-6 py-3 text-sm font-semibold text-white hover:bg-slate-800"
        >
          Start at Level 1 →
        </a>
        <a
          href="/report"
          class="inline-block rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50"
        >
          See the Playwright failure report
        </a>
        <a
          href="/other-usecases"
          class="inline-block rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50"
        >
          Other use-cases →
        </a>
      </div>

      <div class="mt-14 space-y-12">
        {sections.map((s) => (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500">{s.name}</h2>
            <p class="mt-1 max-w-2xl text-sm text-slate-600">{s.description}</p>
            <ol class="mt-4 grid items-start gap-4 sm:grid-cols-2">
              {s.levels.map((l) => (
                <li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-300">
                  <a href={`/${s.slug}/level-${l.localN}/`} class="block">
                    <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                      Level {l.localN}
                    </div>
                    <div class="mt-1 text-lg font-semibold text-slate-900">{l.name}</div>
                    <p class="mt-1 text-sm text-slate-600" set:html={l.blurb} />
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </main>

    <footer class="border-t border-slate-200 py-6 text-center text-xs text-slate-500">
      Demo target only. No analytics, no tracking.
    </footer>
  </body>
</html>
