---
import '../styles/global.css';
import { Code } from 'astro:components';
import { levels } from '../data/levels';

const totalFails = levels.reduce((acc, l) => acc + l.signals.filter((s) => s.status === 'fail').length, 0);

// Pre-compute per-level fix-meter styling so the JSX template doesn't need <= or ?: chains
// (which confuse Astro's compiler inside JSX expressions).
function fixStyles(difficulty: number) {
  const active =
    difficulty <= 2
      ? 'bg-emerald-500'
      : difficulty === 3
      ? 'bg-amber-500'
      : difficulty === 4
      ? 'bg-orange-500'
      : 'bg-rose-600';
  const labelColor =
    difficulty <= 2
      ? 'text-emerald-800'
      : difficulty === 3
      ? 'text-amber-800'
      : difficulty === 4
      ? 'text-orange-800'
      : 'text-rose-800';
  const dotClasses = [1, 2, 3, 4, 5].map((i) =>
    i <= difficulty ? active : 'bg-white ring-1 ring-slate-300'
  );
  return { dotClasses, labelColor };
}

const TEST_SPEC_PATH = 'playwright/levels.spec.ts';
const TEST_SPEC_BLOB_URL = `https://github.com/vaclavnovotny/bot-arena/blob/main/${TEST_SPEC_PATH}`;

const levelData = levels.map((lvl) => {
  const localN = lvl.section === 'Bot detection' ? lvl.n : lvl.n - 5;
  const sectionSlug = lvl.section === 'Bot detection' ? 'bot-detection' : 'selector-resistance';
  const sectionStartLine = lvl.section === 'Bot detection' ? 4 : 46;
  const testStartLine = sectionStartLine + (localN - 1) * 8;
  const testEndLine = testStartLine + 6;
  return {
    ...lvl,
    localN,
    sectionSlug,
    urlPath: `/${sectionSlug}/level-${localN}/`,
    testSourceUrl: `${TEST_SPEC_BLOB_URL}#L${testStartLine}-L${testEndLine}`,
    testSourceLabel: `${TEST_SPEC_PATH}:${testStartLine}-${testEndLine}`,
    playwrightViz:
      lvl.playwright.kind === 'fixable' ? fixStyles(lvl.playwright.difficulty) : null,
    aivaFixesViz:
      lvl.aiva.fixes?.map((f) => ({
        ...f,
        viz: f.kind === 'fixable' ? fixStyles(f.difficulty) : null,
      })) ?? null,
  };
});

const sectionMeta: Record<'Bot detection' | 'Selector resistance', { description: string }> = {
  'Bot detection': {
    description:
      "The site detects automation through fingerprinting, behavioural signals, or third-party challenge. Five levels of increasing sophistication.",
  },
  'Selector resistance': {
    description:
      "The DOM that selector-based automation depends on is absent or randomised. Playwright fails at the selector step before any signal can fire.",
  },
};

const groupedLevels = (
  ['Bot detection', 'Selector resistance'] as const
).map((name) => ({
  name,
  description: sectionMeta[name].description,
  items: levelData.filter((l) => l.section === name),
}));
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Playwright Failure Report — Bot Arena</title>
    <meta
      name="description"
      content="A visual breakdown of what stock Playwright tries to do at each level of Bot Arena and exactly which detection signals make it fail."
    />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-lg font-semibold tracking-tight"><img src="/favicon.svg" alt="" class="h-6 w-6" /><span>Bot Arena</span></a>
        <nav class="flex gap-4 text-sm text-slate-600">
          <a href="/comparison" class="hover:text-slate-900">Comparison</a>
          <a href="/other-usecases" class="hover:text-slate-900">Other use-cases</a>
          <a href="/external" class="hover:text-slate-900">External demos</a>
          <a href="/about" class="hover:text-slate-900">About</a>
          <a href="https://github.com/vaclavnovotny/bot-arena" class="hover:text-slate-900">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Failure report</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight">Playwright vs Bot Arena</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        Seven plain Playwright tests, one per level. Each one tries to sign in. Every test fails — for different reasons across two sections. Below: what each test does, the error Playwright surfaces, and either the detection signals that caught it or the structural mismatch that prevented it.
      </p>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Tests run</div>
          <div class="mt-1 text-3xl font-bold tracking-tight text-slate-900">{levels.length}</div>
        </div>
        <div class="rounded-xl border border-rose-200 bg-rose-50 p-5 shadow-sm">
          <div class="text-xs font-semibold uppercase tracking-wide text-rose-700">Failed</div>
          <div class="mt-1 text-3xl font-bold tracking-tight text-rose-900">{levels.length}</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Signals / mismatches</div>
          <div class="mt-1 text-3xl font-bold tracking-tight text-slate-900">{totalFails}</div>
        </div>
      </div>

      <p class="mt-8 max-w-3xl text-sm text-slate-500">
        Headless Chromium driven by <code class="rounded bg-slate-100 px-1 py-0.5">@playwright/test</code> running against <a class="underline hover:text-slate-900" href="https://bot-arena.jhero.app">bot-arena.jhero.app</a>. Source: <a class="underline hover:text-slate-900" href="https://github.com/vaclavnovotny/bot-arena/blob/main/playwright/levels.spec.ts">playwright/levels.spec.ts</a>.
      </p>

      <nav aria-label="Jump to level" class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Jump to</h2>
        <div class="mt-3 grid gap-6 sm:grid-cols-2">
          {(['Bot detection', 'Selector resistance'] as const).map((sectionName, idx) => {
            const slug = sectionName === 'Bot detection' ? 'bot-detection' : 'selector-resistance';
            const items = levelData.filter((l) => l.section === sectionName);
            return (
              <div>
                <div class="text-sm font-semibold text-slate-900">
                  <a href={`#section-${slug}`} class="hover:underline">
                    Section {idx + 1} · {sectionName}
                  </a>
                </div>
                <ol class="mt-2 space-y-1 text-sm">
                  {items.map((lvl) => (
                    <li class="flex items-center gap-2">
                      <span class="inline-block w-6 text-xs font-mono text-slate-400">{lvl.localN}.</span>
                      <a
                        href={`#${lvl.sectionSlug}-${lvl.localN}`}
                        class="text-slate-700 hover:text-slate-900 hover:underline"
                      >
                        {lvl.title}
                      </a>
                      <span class="ml-auto text-xs text-slate-400">{lvl.family}</span>
                    </li>
                  ))}
                </ol>
              </div>
            );
          })}
        </div>
      </nav>

      <div class="mt-12 space-y-16">
        {groupedLevels.map((group, groupIdx) => (
          <section id={`section-${group.name === 'Bot detection' ? 'bot-detection' : 'selector-resistance'}`} class="scroll-mt-6">
            <div class={`flex items-baseline gap-3 ${groupIdx === 0 ? '' : 'border-t border-slate-200 pt-10'}`}>
              <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
                Section {groupIdx + 1}
              </span>
              <h2 class="text-2xl font-bold tracking-tight text-slate-900">{group.name}</h2>
            </div>
            <p class="mt-2 max-w-3xl text-sm text-slate-600">{group.description}</p>
            <div class="mt-6 space-y-10">
        {group.items.map((lvl) => (
          <article id={`${lvl.sectionSlug}-${lvl.localN}`} class="scroll-mt-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
            <header>
              <div class="flex flex-wrap items-baseline gap-3">
                <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                  Level {lvl.localN}
                </span>
                <h2 class="text-2xl font-bold tracking-tight text-slate-900">{lvl.title}</h2>
                <span class="text-sm text-slate-500">· {lvl.family}</span>
              </div>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-rose-800">
                  Playwright: failed
                </span>
                {lvl.aiva.passes ? (
                  <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-800">
                    AIVA: passes
                  </span>
                ) : (
                  <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-800">
                    AIVA: also fails
                  </span>
                )}
              </div>
            </header>

            <div class="mt-6 grid gap-6 lg:grid-cols-2">
              <div>
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
                    What the test does
                  </h3>
                  <a
                    href={lvl.testSourceUrl}
                    class="font-mono text-[11px] text-slate-500 hover:text-slate-900 hover:underline"
                    target="_blank"
                    rel="noopener"
                  >
                    {lvl.testSourceLabel} ↗
                  </a>
                </div>
                <div class="mt-2 overflow-x-auto rounded-lg bg-slate-900 text-xs">
                  <Code code={lvl.testCode} lang="ts" theme="github-dark" />
                </div>
              </div>

              <div>
                <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
                  What Playwright sees
                </h3>
                <pre class="mt-2 overflow-x-auto rounded-lg bg-rose-50 p-4 font-mono text-xs leading-relaxed text-rose-900 ring-1 ring-rose-200">{lvl.failureMessage}</pre>
              </div>
            </div>

            <details class="group mt-6 rounded-lg bg-sky-50 p-4 ring-1 ring-sky-200">
              <summary class="cursor-pointer text-sm font-semibold text-sky-900">
                Plain-English explanation
                <span class="ml-1 text-xs font-normal text-sky-700 group-open:hidden">(click to expand)</span>
              </summary>
              <div class="mt-4 space-y-3 text-sm leading-relaxed text-sky-950">
                <div>
                  <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-sky-700">
                    The problem
                  </div>
                  <p set:html={lvl.layman.problem} />
                </div>
                <div>
                  <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-sky-700">
                    Why a VNC-driven real browser passes
                  </div>
                  <p set:html={lvl.layman.workaround} />
                </div>
              </div>
            </details>

            <details class="group mt-4 rounded-lg bg-rose-50 p-4 ring-1 ring-rose-200">
              <summary class="flex flex-wrap items-center gap-2 cursor-pointer text-sm font-semibold text-rose-900">
                <span>Playwright context — could this test be fixed in Playwright?</span>
                <span class="text-xs font-normal text-rose-700 group-open:hidden">(click to expand)</span>
                <span class="ml-auto inline-flex items-center gap-2">
                  {lvl.playwright.kind === 'impossible' ? (
                    <>
                      <span class="rounded-full bg-rose-200 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-rose-900">
                        Impossible to fix
                      </span>
                      <span class="text-[10px] font-semibold uppercase tracking-wide text-rose-800">
                        {lvl.playwright.label}
                      </span>
                    </>
                  ) : (
                    <>
                      <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-800">
                        Fixable
                      </span>
                      <span class="flex gap-0.5">
                        {lvl.playwrightViz!.dotClasses.map((cls) => (
                          <span class={`h-2 w-2 rounded-full ${cls}`} />
                        ))}
                      </span>
                      <span class={`text-[10px] font-semibold uppercase tracking-wide ${lvl.playwrightViz!.labelColor}`}>
                        {lvl.playwright.label}
                      </span>
                    </>
                  )}
                </span>
              </summary>
              <div class="mt-4 space-y-3 text-sm leading-relaxed text-rose-950" set:html={lvl.playwright.notes} />
            </details>

            <details class={`group mt-4 rounded-lg p-4 ring-1 ${lvl.aiva.passes ? 'bg-emerald-50 ring-emerald-200' : 'bg-amber-50 ring-amber-200'}`}>
              <summary class={`flex flex-wrap items-center gap-2 cursor-pointer text-sm font-semibold ${lvl.aiva.passes ? 'text-emerald-900' : 'text-amber-900'}`}>
                <span>AIVA context — {lvl.aiva.passes ? 'why this level already passes for AIVA' : 'what would need to change in AIVA to pass this'}</span>
                <span class={`text-xs font-normal group-open:hidden ${lvl.aiva.passes ? 'text-emerald-700' : 'text-amber-700'}`}>(click to expand)</span>
                {lvl.aivaFixesViz ? (
                  <span class="ml-auto inline-flex flex-wrap items-center gap-3">
                    {lvl.aivaFixesViz.map((fix) => (
                      <span class="inline-flex items-center gap-1.5">
                        {fix.kind === 'impossible' ? (
                          <span class="rounded-full bg-rose-200 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-rose-900">
                            Impossible to fix
                          </span>
                        ) : (
                          <>
                            <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-800">
                              Fixable
                            </span>
                            <span class="flex gap-0.5">
                              {fix.viz!.dotClasses.map((cls) => (
                                <span class={`h-2 w-2 rounded-full ${cls}`} />
                              ))}
                            </span>
                          </>
                        )}
                      </span>
                    ))}
                  </span>
                ) : (
                  <span class="ml-auto inline-flex items-center gap-1.5">
                    <span class="text-[10px] font-semibold uppercase tracking-wide text-emerald-800">
                      ✓ passes natively
                    </span>
                  </span>
                )}
              </summary>

              {lvl.aivaFixesViz && lvl.aivaFixesViz.length > 0 && (
                <div class="mt-4 space-y-3">
                  {lvl.aivaFixesViz.map((fix, idx) => (
                    <div class="rounded-lg bg-white/70 p-4 ring-1 ring-slate-200">
                      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                        <div class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">
                          {lvl.aivaFixesViz!.length > 1 ? `Path ${idx + 1}` : 'Fix complexity'}
                        </div>
                        {fix.kind === 'impossible' ? (
                          <span class="rounded-full bg-rose-200 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-rose-900">
                            Impossible to fix
                          </span>
                        ) : (
                          <>
                            <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-emerald-800">
                              Fixable
                            </span>
                            <div class="flex items-center gap-1.5">
                              {fix.viz!.dotClasses.map((cls) => (
                                <span class={`h-3 w-3 rounded-full ${cls}`} />
                              ))}
                            </div>
                          </>
                        )}
                        <div class={`text-base font-bold ${fix.kind === 'fixable' ? fix.viz!.labelColor : 'text-rose-800'}`}>{fix.label}</div>
                        <div class="ml-auto text-xs italic text-slate-600">{fix.estimate}</div>
                      </div>
                      <div class="mt-3 flex flex-wrap gap-2">
                        {fix.tags.map((tag) => (
                          <span class="rounded-full bg-white px-2.5 py-0.5 text-xs font-medium text-slate-700 ring-1 ring-slate-300">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {lvl.aiva.passes && !lvl.aivaFixesViz && (
                <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900">
                  ✓ No fix needed — passes by construction
                </div>
              )}

              <div class={`mt-4 space-y-3 text-sm leading-relaxed ${lvl.aiva.passes ? 'text-emerald-950' : 'text-amber-950'}`} set:html={lvl.aiva.notes} />
            </details>

            <div class="mt-6">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
                Why it failed — Detection Log
              </h3>
              <ul class="mt-3 space-y-2">
                {lvl.signals.map((s) => {
                  const badge =
                    s.status === 'fail'
                      ? 'bg-rose-600 text-white'
                      : s.status === 'pass'
                      ? 'bg-emerald-600 text-white'
                      : 'bg-slate-500 text-white';
                  return (
                    <li class="flex items-start gap-3 rounded-lg bg-slate-50 px-3 py-2 ring-1 ring-slate-100">
                      <span class={`mt-0.5 inline-block rounded px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wide ${badge}`}>
                        {s.status}
                      </span>
                      <span class="font-mono text-xs text-slate-800">
                        <span class="font-semibold">{s.id}</span>
                        <span class="text-slate-500"> — {s.detail}</span>
                      </span>
                    </li>
                  );
                })}
              </ul>
            </div>

            <div class="mt-6 flex flex-wrap gap-3 text-sm">
              <a
                href={lvl.urlPath}
                class="rounded-md border border-slate-300 bg-white px-3 py-1.5 font-medium text-slate-700 hover:bg-slate-50"
              >
                Visit Level {lvl.localN} →
              </a>
              {lvl.n > 1 && (
                <a
                  href={lvl.n === 6 ? '#bot-detection-5' : `#${lvl.sectionSlug}-${lvl.localN - 1}`}
                  class="rounded-md border border-slate-300 bg-white px-3 py-1.5 font-medium text-slate-500 hover:bg-slate-50"
                >
                  ↑ Previous
                </a>
              )}
              {lvl.n < 7 && (
                <a
                  href={lvl.n === 5 ? '#selector-resistance-1' : `#${lvl.sectionSlug}-${lvl.localN + 1}`}
                  class="rounded-md border border-slate-300 bg-white px-3 py-1.5 font-medium text-slate-500 hover:bg-slate-50"
                >
                  Next ↓
                </a>
              )}
            </div>
          </article>
        ))}
            </div>
          </section>
        ))}
      </div>

      <section class="mt-16 rounded-2xl border border-emerald-200 bg-emerald-50 p-8 shadow-sm">
        <h2 class="text-xl font-bold tracking-tight text-emerald-900">What changes with VNC AIVA</h2>
        <p class="mt-3 max-w-3xl text-sm text-emerald-900">
          Point the same seven tests at the classic AIVA — a real headed Chrome on a Linux host, clicked through VNC at the OS level, with image-based recognition instead of selectors. The five detection levels close down to one or two trivial fixes. The two selector-resistant levels are unblocked by construction — pixel-aware automation does not care whether the DOM is empty or randomised.
        </p>
        <p class="mt-3 max-w-3xl text-sm text-emerald-900">
          The difference is not patches, plugins, or stealth tricks. It is that VNC-AIVA <em>is</em> a real browser session driven by real OS-level input, with image recognition that reads the screen instead of the DOM.
        </p>
      </section>

      <footer class="mt-16 border-t border-slate-200 pt-6 text-center text-xs text-slate-500">
        Static report generated on 2026-05-12 against bot-arena commit <code>c22e2ac</code>. Re-run with <code class="rounded bg-slate-100 px-1 py-0.5">npx playwright test</code>.
      </footer>
    </main>
  </body>
</html>
