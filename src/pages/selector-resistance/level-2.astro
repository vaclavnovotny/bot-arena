---
import LevelLayout from '../../components/LevelLayout.astro';

const r = (): string => Math.random().toString(36).slice(2, 10);
const ids = {
  form: r(),
  email: r(),
  password: r(),
  submit: r(),
  labelClass1: r(),
  labelClass2: r(),
  inputClass1: r(),
  inputClass2: r(),
  btnClass: r(),
};

const measured = `
- The form is a real HTML form with real <code>&lt;input&gt;</code> elements — but every <code>id</code>, <code>name</code>, and <code>class</code> is randomised on every page request.
- There are no <code>&lt;label&gt;</code> elements (and no <code>aria-label</code>, no <code>placeholder</code>) — the "Email" and "Password" text are plain <code>&lt;div&gt;</code>s that the input has no programmatic link to.
- Playwright's accessibility-based locators (<code>getByLabel</code>, <code>getByRole('textbox', { name })</code>, <code>getByPlaceholder</code>) all return empty.
- A test could fall back to brittle structural selectors (<code>input:nth-of-type(1)</code>) — until the form reorders or grows.
- An image-aware automation tool reads "Email" off the screen and clicks the input box right under it. The DOM mess is invisible to it.
`;

const usedBy: Array<{ name: string; note: string }> = [
  {
    name: 'Material UI (MUI), Chakra UI, Mantine',
    note: 'CSS-in-JS frameworks generate hashed class names like <code>css-1abc23</code> on every build. Selectors written against those classes break with every release.',
  },
  {
    name: 'styled-components, emotion',
    note: 'Every styled element ships a generated hash class. Many production React apps (Stripe Dashboard, Notion, Vercel, GitHub Primer-styled surfaces) ride on these.',
  },
  {
    name: 'Vue scoped CSS, Angular emulated encapsulation',
    note: 'Vue injects a per-component <code>data-v-XXXXXXX</code> hash; Angular adds <code>_ngcontent-c123</code> attributes. Hashes change between builds.',
  },
  {
    name: 'Salesforce Lightning / ServiceNow',
    note: 'Both generate per-instance IDs (<code>lightning-id-…</code>, <code>sn-id-…</code>) and rotate them across releases. Cross-tenant test recordings always break.',
  },
  {
    name: 'ASP.NET WebForms',
    note: 'Postback IDs like <code>__ctl00$ContentPlaceHolder1$gv$ctl05</code> change as soon as the page tree is edited in Visual Studio. Still in heavy use across enterprise back-office portals.',
  },
  {
    name: 'Anti-bot WAFs (Cloudflare Bot Management, Akamai Bot Manager, DataDome, HUMAN/PerimeterX)',
    note: 'Edge workers inject per-session attribute randomisation in front of any site — used heavily by airlines, ticketing platforms, and high-value retail.',
  },
  {
    name: 'Banking & ticketing login flows',
    note: 'Many banks rotate input <code>name=</code> attributes every session to defeat credential stuffing. Ticketmaster / Live Nation are famous for rotating selectors during high-demand sales.',
  },
];
---
<LevelLayout
  section="selector-resistance"
  localN={2}
  title="Dynamic selectors"
  summary="Real form, but every identifier rerolls on each request."
  measured={measured}
>
  <form
    id={`form-${ids.form}`}
    class="max-w-sm rounded-xl border border-slate-200 bg-white p-6 shadow-sm data-[arena-state=granted]:border-emerald-300 data-[arena-state=blocked]:border-rose-300"
    data-arena-form
  >
    <h2 class="text-base font-semibold text-slate-900">Sign in</h2>
    <p class="mt-1 text-sm text-slate-500">Demo target — credentials are not checked.</p>

    <div class={`mt-4 block text-sm font-medium text-slate-700 ${ids.labelClass1}`}>
      Email
      <input
        type="text"
        id={ids.email}
        name={ids.email}
        class={`mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none ${ids.inputClass1}`}
        value="user@example.com"
      />
    </div>

    <div class={`mt-3 block text-sm font-medium text-slate-700 ${ids.labelClass2}`}>
      Password
      <input
        type="text"
        id={ids.password}
        name={ids.password}
        class={`mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none ${ids.inputClass2}`}
        value="hunter2"
      />
    </div>

    <button
      type="submit"
      id={ids.submit}
      class={`mt-5 w-full rounded-md bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800 ${ids.btnClass}`}
    >
      Sign in
    </button>

    <div class="mt-4 hidden text-sm font-medium text-emerald-700" data-arena-granted>
      ✓ Access granted
    </div>
    <div class="mt-4 hidden text-sm font-medium text-rose-700" data-arena-blocked>
      ✗ Blocked
    </div>
  </form>
  <p class="mt-3 max-w-sm text-xs text-slate-500">
    Refresh the page. Every <code>id</code>, <code>name</code>, and <code>class</code> on the form is different.
    There are no <code>&lt;label&gt;</code> elements at all — just <code>&lt;div&gt;</code>s.
  </p>

  <section class="mt-10 max-w-2xl">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500">
      Production apps using this technique
    </h2>
    <ul class="mt-3 grid gap-2 text-sm">
      {usedBy.map((app) => (
        <li class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
          <span class="font-semibold text-slate-900">{app.name}</span>
          <span class="text-slate-600"> — <span set:html={app.note} /></span>
        </li>
      ))}
    </ul>
  </section>
</LevelLayout>

<script is:inline>
  document.querySelectorAll('[data-arena-form]').forEach((form) => {
    form.addEventListener('submit', (ev) => {
      ev.preventDefault();
      const emailInput = form.querySelectorAll('input')[0];
      const passwordInput = form.querySelectorAll('input')[1];
      const ok = !!emailInput.value && !!passwordInput.value;
      form.setAttribute('data-arena-state', ok ? 'granted' : 'blocked');
      form.querySelector('[data-arena-granted]').classList.toggle('hidden', !ok);
      form.querySelector('[data-arena-blocked]').classList.toggle('hidden', ok);
      if (window.__bus) {
        window.__bus.emit({
          id: 'level7-submit',
          name: 'Form submitted',
          status: ok ? 'pass' : 'fail',
          detail: ok ? 'inputs found and filled' : 'inputs empty',
        });
      }
    });
  });
</script>

<script>
  window.__bus?.emit({
    id: 'level7-armed',
    name: 'Form rendered with randomised attributes',
    status: 'info',
    detail: 'Refresh to see id/name/class roll over. No <label> elements, no aria-label, no placeholder.',
  });
</script>
