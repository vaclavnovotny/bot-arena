---
import LevelLayout from '../../components/LevelLayout.astro';

const measured = `
- The login form lives inside an <code>&lt;iframe&gt;</code>. Its document is a separate browsing context.
- Playwright's page-scoped locators (<code>page.getByLabel</code>, <code>page.getByRole</code>) only query the <strong>main frame</strong>. They do not descend into child frames. To reach the form a test must call <code>page.frameLocator('iframe').getByLabel(...)</code> explicitly.
- Most test suites are not written iframe-aware. A standard <code>page.getByLabel('Email')</code> times out with "no element matched", and the failure is exactly the same shape as if the form did not exist at all.
- This pattern is everywhere in production: Stripe Elements, Auth0 Universal Login, embedded support chats, social-login widgets, Cloudflare Turnstile itself.
- A vision-based automation tool sees the form as part of the rendered page — frame boundaries don't show up in the screenshot.
`;

interface AppEntry {
  name: string;
  note: string;
  marketShare?: string;
  users?: string;
}

const usedBy: AppEntry[] = [
  {
    name: 'Stripe Elements (payment fields)',
    note: 'Card number, expiry, and CVC are each in their own cross-origin iframe served from <code>js.stripe.com</code>. PCI-mandated isolation; cross-origin so no Playwright access at all.',
    marketShare: '~17% of online payment processing (largest gateway)',
    users: '4M+ businesses; processes $1T+ payment volume / year',
  },
  {
    name: 'Auth0 Universal Login (embedded mode)',
    note: 'Auth0\'s embeddable login dialog runs in an iframe. The "Lock" widget API is the supported interaction surface; raw selectors do not work.',
    marketShare: 'Okta-Auth0 ~5–8% of IAM / CIAM market',
    users: '16K+ customers; billions of monthly authentications',
  },
  {
    name: 'Cloudflare Turnstile and reCAPTCHA',
    note: 'CAPTCHA challenges always render as cross-origin iframes for security. Test harnesses use test-mode keys or paid solver services.',
    marketShare: 'reCAPTCHA ~60% of CAPTCHA market; Turnstile growing fast',
    users: 'reCAPTCHA on 13M+ websites; Cloudflare fronts ~20% of internet traffic',
  },
  {
    name: 'Intercom, Drift, Zendesk, HubSpot Chat',
    note: 'Embedded support and chat widgets render inside iframes. Tests that want to interact with them must use vendor-specific automation APIs.',
    marketShare: 'Zendesk ~7% CX/CRM; HubSpot ~5% CRM',
    users: 'Zendesk 130K+ customers; HubSpot 215K+; Intercom 25K+; Drift 5K+',
  },
  {
    name: 'Sign-in with Google / Apple / Facebook',
    note: 'One-tap sign-in buttons and One Tap prompts are iframes from the identity provider. Cross-origin; selector-based testing falls back to manual auth fixtures.',
    marketShare: 'Google Sign-in ~70% of social login market',
    users: 'Embedded on millions of sites; ~1.8B Gmail accounts + 1B+ Apple ID + 3B Facebook accounts addressable',
  },
  {
    name: 'Sentry user-feedback dialog and many SaaS embed widgets',
    note: 'Anything labelled "embeddable widget" — Calendly, Typeform inline, Cal.com, HelloSign — almost always ships as an iframe.',
    marketShare: 'Calendly leads scheduling SaaS; Sentry leads error monitoring',
    users: 'Sentry 100K+ orgs / 4M devs; Calendly 20M+ users; Typeform 150K+ customers',
  },
  {
    name: 'Embedded ad slots and analytics consent banners',
    note: 'GAM ad slots, Google Tag Manager preview, OneTrust/TrustArc consent banners — most run inside iframes for security and CSP isolation.',
    marketShare: 'GAM ~30%+ programmatic ads; OneTrust ~50% consent management',
    users: 'GTM on 36M+ websites; OneTrust used across most Fortune 500',
  },
];

// Self-contained inner document via srcdoc, so this is one file.
const innerDoc = `
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
      form { background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
      h2 { font: bold 16px system-ui; margin: 0 0 4px; color: #0f172a; }
      p.lead { font: 14px system-ui; color: #64748b; margin: 0 0 16px; }
      label { display: block; font: 500 13px system-ui; color: #334155; margin-top: 12px; }
      input { display: block; width: 100%; box-sizing: border-box; border: 1px solid #cbd5e1; border-radius: 6px; padding: 8px 12px; font: 14px system-ui; margin-top: 4px; }
      input:focus { outline: none; border-color: #475569; }
      button { display: block; width: 100%; margin-top: 20px; background: #0f172a; color: white; font: bold 14px system-ui; padding: 8px 12px; border: none; border-radius: 6px; cursor: pointer; }
      button:hover { background: #1e293b; }
      .ok { color: #059669; font: 600 14px system-ui; margin-top: 16px; display: none; }
    </style>
  </head>
  <body>
    <form id="frame-form">
      <h2>Sign in</h2>
      <p class="lead">Demo target inside an iframe.</p>
      <label>Email
        <input type="email" name="email" value="user@example.com" />
      </label>
      <label>Password
        <input type="password" name="password" value="hunter2" />
      </label>
      <button type="submit">Sign in</button>
      <div class="ok" id="ok-msg">&#10003; Access granted</div>
    </form>
    <script>
      document.getElementById('frame-form').addEventListener('submit', function (ev) {
        ev.preventDefault();
        document.getElementById('ok-msg').style.display = 'block';
        try {
          window.parent.postMessage({ type: 'iframe-submit' }, '*');
        } catch (_) {}
      });
    </script>
  </body>
</html>
`;
---
<LevelLayout
  section="selector-resistance"
  localN={4}
  title="Iframe-embedded form"
  summary="Real form, but in a child frame. Page-scoped selectors do not see into it."
  measured={measured}
>
  <div class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm" style="width: 380px;">
    <iframe
      title="login-frame"
      srcdoc={innerDoc}
      style="display: block; width: 360px; height: 320px; border: 0; border-radius: 6px;"
    ></iframe>
  </div>
  <p class="mt-3 max-w-sm text-xs text-slate-500">
    The form is in a separate document loaded via <code>&lt;iframe srcdoc=&quot;...&quot;&gt;</code>.
    Playwright needs an explicit <code>page.frameLocator('iframe')</code> to reach it.
  </p>

  <section class="mt-10 max-w-2xl">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500">
      Production apps using this technique
    </h2>
    <ul class="mt-3 grid gap-2 text-sm">
      {usedBy.map((app) => (
        <li class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm">
          <div>
            <span class="font-semibold text-slate-900">{app.name}</span>
            <span class="text-slate-600"> — <span set:html={app.note} /></span>
          </div>
          {(app.marketShare || app.users) && (
            <div class="mt-2 flex flex-wrap gap-1.5 text-[11px]">
              {app.marketShare && (
                <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2 py-0.5 text-slate-700">
                  <span class="font-semibold uppercase tracking-wide text-slate-500">Market</span>
                  <span>{app.marketShare}</span>
                </span>
              )}
              {app.users && (
                <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2 py-0.5 text-slate-700">
                  <span class="font-semibold uppercase tracking-wide text-slate-500">Users</span>
                  <span>{app.users}</span>
                </span>
              )}
            </div>
          )}
        </li>
      ))}
    </ul>
    <p class="mt-3 text-[11px] text-slate-400">
      Figures are approximate / company-disclosed (~2024–2025). Sources: company filings, industry reports (Gartner, IDC, BuiltWith, npm stats), and public DAU disclosures.
    </p>
  </section>
</LevelLayout>

<script is:inline>
  window.addEventListener('message', (ev) => {
    if (ev.data && ev.data.type === 'iframe-submit' && window.__bus) {
      window.__bus.emit({
        id: 'iframe-submit',
        name: 'Iframe form submitted',
        status: 'pass',
        detail: 'inner frame posted submit message to parent; access granted inside the frame',
      });
    }
  });
  if (window.__bus) {
    window.__bus.emit({
      id: 'iframe-armed',
      name: 'Iframe form mounted',
      status: 'info',
      detail: 'page.getByLabel on the main page will not traverse into the iframe.',
    });
  }
</script>
